# Drape environment variables.
# Copy to .env.local for Next, and set the same server-side vars on the Railway worker.
# NEVER commit real values. Service-role and FAL keys are server-side only.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # server-side only, bypasses RLS, never expose to client

# --- fal.ai ---
FAL_KEY=                          # server-side only, never committed
FAL_WEBHOOK_SECRET=               # shared-secret fallback for verifying fal webhook deliveries

# --- Anthropic (Claude prompt-director: analyze, compose, fidelity gate) ---
ANTHROPIC_API_KEY=                # server-side only; without it the director uses a deterministic fallback

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Worker <-> Next auth ---
WORKER_SHARED_SECRET=             # bearer secret between Next app and Railway worker

# --- Feature flags ---
DRAPE_VIDEO_ENABLED=              # set to "true" to enable video (i2v). Default OFF until the
                                  # final-pass video rebuild verifies registry slug = route field =
                                  # worker slug. When off, the video endpoint fails cleanly, no charge.
