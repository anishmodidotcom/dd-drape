# Oviya (internal codename "drape") environment variables.
# Copy to .env.local for Next, and set the same server-side vars on the Railway worker.
# NEVER commit real values. Service-role and provider keys are server-side only.
#
# NOTE: as of the infra migration, ALL Supabase values below point at Oviya's OWN Supabase project
# (no longer the shared CGE project). Only the VALUES changed; the variable NAMES are unchanged.

# --- Supabase (Oviya's own project) ---
NEXT_PUBLIC_SUPABASE_URL=          # new Oviya project URL, e.g. https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=     # new Oviya project anon (publishable) key
SUPABASE_SERVICE_ROLE_KEY=         # new Oviya project service-role key. Server-side only, bypasses RLS, never expose to client

# --- fal.ai ---
FAL_KEY=                          # server-side only, never committed
FAL_WEBHOOK_SECRET=               # shared-secret fallback for verifying fal webhook deliveries

# --- Anthropic (Claude prompt-director: analyze, compose, fidelity gate) ---
ANTHROPIC_API_KEY=                # server-side only; without it the director uses a deterministic fallback

# --- App ---
NEXT_PUBLIC_APP_URL=https://oviyastudio.com   # production domain (use http://localhost:3000 for local dev)

# --- Admin (superadmin allowlist; server-side only, never a client check) ---
ADMIN_EMAILS=                     # comma-separated extra admin login emails. support@ and admin@oviyastudio.com are built in.

# --- Worker <-> Next auth ---
WORKER_SHARED_SECRET=             # bearer secret between Next app and Railway worker

# --- Feature flags ---
DRAPE_VIDEO_ENABLED=              # set to "true" to enable video (i2v). Default OFF until the worker is
                                  # confirmed running. When off, the video endpoint fails cleanly, no charge.

# --- Gemini (BRAND/SITE/PRESET imagery ONLY, never the product engine) ---
GEMINI_API_KEY=                   # server-side only; used by scripts/generate-assets*.ts

# --- Email: Resend SMTP is configured in the Supabase dashboard (Auth -> SMTP), not here.
#     Sender support@oviyastudio.com, host smtp.resend.com, port 465, user "resend", password = Resend API key.
